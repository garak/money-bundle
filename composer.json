{
    "name": "garak/money-bundle",
    "type": "symfony-bundle",
    "description": "Bundle to use a single mapped currency with moneyphp/money",
    "keywords": ["Symfony", "money"],
    "license": "LGPL-3.0-or-later",
    "authors": [
        {
            "name": "Massimiliano Arione",
            "email": "garakkio@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "doctrine/dbal": "^4.0",
        "moneyphp/money": "^4.0",
        "symfony/config": "^7.4 || ^8.0",
        "symfony/dependency-injection": "^7.4 || ^8.0",
        "symfony/form": "^7.4 || ^8.0",
        "symfony/http-kernel": "^7.4 || ^8.0",
        "twig/twig": "^3.27 || ^4.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpunit/phpunit": "^12.5 || ^13.2"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.x-dev"
        }
    },
    "autoload": {
        "psr-4": {
            "Garak\\Money\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Garak\\Money\\Tests\\": "tests"
        }
    }
}
